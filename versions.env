# Single source of truth for pinned tool versions.
# Sourced by install-mac.sh, install-linux.sh, and lib/common.sh.
#
# Bump a version here and both macOS and Linux installs pick it up.
GO_VERSION="1.26.4"
NODE_VERSION="24.16.0"   # v24 "Krypton" LTS line
PYTHON_VERSION="3.14"
RUST_VERSION="1.96.0"
NEOVIM_VERSION="0.12.3"   # Linux tarball only; macOS uses Homebrew's neovim
OP_VERSION="2.34.1"      # 1Password CLI (op); same standalone zip on mac & linux
